# Dev: target del proxy /api -> backend (npm run dev). El backend no tiene CORS.
VITE_API_PROXY="https://symtechven.com"

# Origen para completar las fotos que el back manda como ruta relativa
# (ej. /fotos/personas/abc.jpg). Si el back ya manda URLs completas, no se usa.
VITE_MEDIA_URL="https://symtechven.com"

# Solo si el backend habilita CORS o sirves el front desde su mismo dominio.
# VITE_API_URL="https://symtechven.com/api"
